# --- Microsoft Entra (Azure AD) app registration ---
# Application (client) ID from the App registrations blade in portal.azure.com.
# See SETUP_GRAPH.md (or run scripts/register-app.sh).
MICROSOFT_CLIENT_ID=

# Used ONLY by scripts/test-graph-connection.mjs (the device-code dumper).
# The API derives its authority from MICROSOFT_AUTHORITY below.
# "consumers" for personal Microsoft accounts, "common" for both, or a tenant ID.
MICROSOFT_TENANT_ID=consumers

# --- Workbook ---
# The full OneDrive sharing URL of the Excel file (the same one you open in the browser).
# This URL contains a sharing capability token; treat it as a secret.
ONEDRIVE_WORKBOOK_URL=

# Worksheet name inside the workbook to read. Usually "Sheet1".
WORKSHEET_NAME=Sheet1

# --- API server (apps/api) ---
# Source of expense data: "graph" (live Microsoft Graph) or "dump" (read latest
# dumps/*.json file). Default is "graph". In dump mode no Graph credentials are
# needed and browser sign-in is disabled.
EXPENSES_SOURCE=graph

# Demo mode: set to "true" to serve in-memory funny fake data instead of the
# real database/workbook. Overrides EXPENSES_SOURCE. Useful for demos and
# screenshots — nothing is persisted, sign-in is disabled.
# DEMO_MODE=false

# Microsoft identity authority (used by both API and SPA).
# https://login.microsoftonline.com/consumers for personal MSAs (default).
MICROSOFT_AUTHORITY=https://login.microsoftonline.com/consumers

# Comma-separated Graph scopes the SPA requests on the user's behalf.
GRAPH_SCOPES=Files.ReadWrite,User.Read

# Port the Express API listens on.
PORT=4000
# Directory the API reads dump-*.json files from (used in dump mode).
# Relative paths resolve from apps/api when running `npm run dev -w @expenses/api`.
DUMPS_DIR=../../dumps
# Pino log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info
# development | production | test (controls log formatting)
NODE_ENV=development
# Allowed CORS origin for the web app
CORS_ORIGIN=http://localhost:4200
