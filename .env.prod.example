# Production env for the LXC deployment.
# Copy to .env.prod, fill in the secrets, then `docker compose -f compose.deploy.yml up -d --build`.

# ---- Runtime ----------------------------------------------------------------
NODE_ENV=production
PORT=4000
LOG_LEVEL=info

# ---- App layout (paths inside the container) --------------------------------
SERVE_SPA=true
SPA_DIR=/app/apps/web/dist/web/browser
DB_PATH=/data/expenses.db
DUMPS_DIR=/data/dumps

# ---- Data source ------------------------------------------------------------
# Live workbook reads via Microsoft Graph. Set to "dump" for offline JSON
# dumps. (Demo mode is toggled in-app from the Settings page; no env needed.)
EXPENSES_SOURCE=graph

# ---- App-level auth ---------------------------------------------------------
# When true, every /api/* route (not just Graph passthrough) requires the
# Microsoft Bearer token the SPA already sends after MSAL sign-in.
# Recommended ON when the app is reachable from any device beyond your own.
REQUIRE_AUTH=true

# ---- Microsoft Graph --------------------------------------------------------
# Azure app registration (SPA). Make sure the tailnet hostname is in the
# allowed redirect URIs (e.g. https://expenses-host.<tailnet>.ts.net).
MICROSOFT_CLIENT_ID=00000000-0000-0000-0000-000000000000
MICROSOFT_AUTHORITY=https://login.microsoftonline.com/consumers
GRAPH_SCOPES=Files.ReadWrite,User.Read
ONEDRIVE_WORKBOOK_URL=https://onedrive.live.com/edit?...
WORKSHEET_NAME=Sheet1

# ---- CORS -------------------------------------------------------------------
# Same-origin in production (SPA served by the API) -> CORS is effectively a
# no-op. Leave as-is unless you split the SPA onto a different origin.
CORS_ORIGIN=http://localhost:4200
