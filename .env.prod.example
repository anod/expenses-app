# Production env for the LXC deployment.
# Copy to .env.prod, fill in the secrets, then `docker compose -f compose.deploy.yml up -d --build`.

# ---- Runtime ----------------------------------------------------------------
NODE_ENV=production
PORT=4000
LOG_LEVEL=info

# ---- App layout (paths inside the container) --------------------------------
SERVE_SPA=true
SPA_DIR=/app/apps/web/dist/web/browser
DB_PATH=/data/expenses.db
DUMPS_DIR=/data/dumps

# ---- Data source ------------------------------------------------------------
# Live workbook reads via Microsoft Graph. Set to "dump" for offline JSON
# dumps. (Demo mode is toggled in-app from the Settings page; no env needed.)
EXPENSES_SOURCE=graph

# ---- App-level auth ---------------------------------------------------------
# When true, every /api/* route (not just Graph passthrough) requires a
# Microsoft Bearer token whose `aud` matches our API audience
# (api://<MICROSOFT_CLIENT_ID> by default). The token is also validated
# against Microsoft's JWKS (signature, iss, aud, exp, nbf), checked for
# the `access` scope, and bound to ALLOWED_OIDS below.
# Recommended ON whenever the app is reachable beyond your own machine.
REQUIRE_AUTH=true

# Comma-separated list of Microsoft `oid` values that may call the API.
# REQUIRED when REQUIRE_AUTH=true. Without this, any Microsoft account that
# consents to the app could obtain a valid token and call your API.
# Find your oid by running `scripts/register-app.sh` (prints it at the end)
# or by signing into https://jwt.ms with the SPA and copying the `oid` claim.
ALLOWED_OIDS=

# Microsoft tenant whose JWKS the API uses to validate tokens. For personal
# Microsoft accounts always use 9188040d-6c67-4c5b-b112-36a304b66dad — that's
# the `tid` claim Microsoft stamps on every personal-MSA token regardless of
# which authority the SPA points at.
MICROSOFT_TENANT_ID=9188040d-6c67-4c5b-b112-36a304b66dad

# Expected `aud` claim on incoming API tokens. Leave the line out (or
# COMMENTED) to use the default `api://<MICROSOFT_CLIENT_ID>`. Setting it
# to an empty string previously broke scope resolution (regression: the
# computed scope became "/access"); the loader now treats empty as unset,
# but it's cleaner to just omit the line.
# API_AUDIENCE=

# ---- Microsoft Graph --------------------------------------------------------
# Azure app registration (SPA). Make sure the tailnet hostname is in the
# allowed redirect URIs (e.g. https://expenses-host.<tailnet>.ts.net).
MICROSOFT_CLIENT_ID=00000000-0000-0000-0000-000000000000
MICROSOFT_AUTHORITY=https://login.microsoftonline.com/consumers
GRAPH_SCOPES=Files.ReadWrite,User.Read
# Optional: also editable in-app under Settings (DB-stored, wins over env).
ONEDRIVE_WORKBOOK_URL=
WORKSHEET_NAME=Sheet1

# Optional: separate OneDrive workbook URL for the ESOP estimator.
# This URL contains a sharing capability token; treat it as a secret.
ESOP_WORKBOOK_URL=
ESOP_WORKSHEET_NAME=ESOP

# ---- CORS -------------------------------------------------------------------
# Must be the exact origin (scheme + host[+port]) the SPA is loaded from,
# e.g. https://expenses.<your-tailnet>.ts.net. POST /api/demo enforces an
# Origin/Referer match against this value as browser-CSRF defense, so a
# wrong value will break the in-app demo toggle and any future cross-origin
# split. `*` is rejected by the API. Leave as localhost only for local dev.
CORS_ORIGIN=https://expenses.example.ts.net
