{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "description": "Anchor balance columns with expected spending as a line; mirrors the app chart rendered directly with Vega-Lite.",
  "title": {
    "text": "Projected Balance",
    "subtitle": "Columns show anchor balance; line shows expected spending",
    "anchor": "start",
    "fontSize": 16,
    "subtitleFontSize": 12,
    "subtitleColor": "#6b6472"
  },
  "width": 680,
  "height": 320,
  "data": {
    "values": [
      {
        "date": "2026-01-10",
        "anchorBalance": 18400,
        "spendingAtAnchor": 0,
        "splitCcAtAnchor": 0
      },
      {
        "date": "2026-02-10",
        "anchorBalance": 16250,
        "spendingAtAnchor": 3850,
        "splitCcAtAnchor": 900
      },
      {
        "date": "2026-03-10",
        "anchorBalance": 14100,
        "spendingAtAnchor": 4100,
        "splitCcAtAnchor": 1250
      },
      {
        "date": "2026-04-10",
        "anchorBalance": 11950,
        "spendingAtAnchor": 3950,
        "splitCcAtAnchor": 1500
      },
      {
        "date": "2026-05-10",
        "anchorBalance": 9800,
        "spendingAtAnchor": 4200,
        "splitCcAtAnchor": 1750
      },
      {
        "date": "2026-06-10",
        "anchorBalance": 11200,
        "spendingAtAnchor": 3600,
        "splitCcAtAnchor": 1200
      },
      {
        "date": "2026-07-10",
        "anchorBalance": 8700,
        "spendingAtAnchor": 4550,
        "splitCcAtAnchor": 2100
      }
    ]
  },
  "transform": [
    {
      "calculate": "datum.spendingAtAnchor",
      "as": "expectedSpending"
    },
    {
      "calculate": "datum.splitCcAtAnchor",
      "as": "creditCardPayments"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "bar",
        "cornerRadiusTopLeft": 5,
        "cornerRadiusTopRight": 5,
        "color": "#d7c8f5",
        "stroke": "#6750a4",
        "strokeWidth": 0.9,
        "opacity": 0.96,
        "width": 56
      },
      "encoding": {
        "x": {
          "field": "date",
          "type": "ordinal",
          "title": null,
          "sort": {
            "field": "date",
            "order": "ascending"
          },
          "scale": {
            "paddingInner": 0.08,
            "paddingOuter": 0.03
          },
          "axis": {
            "labelExpr": "timeFormat(toDate(datum.label), '%b %d')",
            "labelAngle": 0,
            "labelFontSize": 12,
            "labelColor": "#49454f"
          }
        },
        "y": {
          "field": "anchorBalance",
          "type": "quantitative",
          "title": "Amount",
          "axis": {
            "format": ",.0f",
            "labelFontSize": 11
          }
        },
        "tooltip": [
          {
            "field": "date",
            "type": "temporal",
            "title": "Anchor period",
            "format": "%b %d, %Y"
          },
          {
            "field": "anchorBalance",
            "type": "quantitative",
            "title": "Anchor balance",
            "format": ",.0f"
          },
          {
            "field": "expectedSpending",
            "type": "quantitative",
            "title": "Expected spending",
            "format": ",.0f"
          },
          {
            "field": "creditCardPayments",
            "type": "quantitative",
            "title": "Split CC @ anchor",
            "format": ",.0f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "line",
        "strokeWidth": 3,
        "interpolate": "monotone",
        "color": "#006d75"
      },
      "encoding": {
        "x": {
          "field": "date",
          "type": "ordinal",
          "sort": {
            "field": "date",
            "order": "ascending"
          },
          "scale": {
            "paddingInner": 0.08,
            "paddingOuter": 0.03
          }
        },
        "y": {
          "field": "expectedSpending",
          "type": "quantitative"
        },
        "tooltip": [
          {
            "field": "date",
            "type": "temporal",
            "title": "Anchor period",
            "format": "%b %d, %Y"
          },
          {
            "field": "expectedSpending",
            "type": "quantitative",
            "title": "Expected spending",
            "format": ",.0f"
          },
          {
            "field": "anchorBalance",
            "type": "quantitative",
            "title": "Anchor balance",
            "format": ",.0f"
          },
          {
            "field": "creditCardPayments",
            "type": "quantitative",
            "title": "Split CC @ anchor",
            "format": ",.0f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 72,
        "stroke": "white",
        "strokeWidth": 1.5,
        "color": "#006d75"
      },
      "encoding": {
        "x": {
          "field": "date",
          "type": "ordinal",
          "sort": {
            "field": "date",
            "order": "ascending"
          },
          "scale": {
            "paddingInner": 0.08,
            "paddingOuter": 0.03
          }
        },
        "y": {
          "field": "expectedSpending",
          "type": "quantitative"
        },
        "tooltip": [
          {
            "field": "date",
            "type": "temporal",
            "title": "Anchor period",
            "format": "%b %d, %Y"
          },
          {
            "field": "expectedSpending",
            "type": "quantitative",
            "title": "Expected spending",
            "format": ",.0f"
          },
          {
            "field": "anchorBalance",
            "type": "quantitative",
            "title": "Anchor balance",
            "format": ",.0f"
          },
          {
            "field": "creditCardPayments",
            "type": "quantitative",
            "title": "Split CC @ anchor",
            "format": ",.0f"
          }
        ]
      }
    }
  ],
  "config": {
    "background": "#fffbff",
    "view": {
      "stroke": null
    },
    "axis": {
      "grid": true,
      "gridColor": "#eee8f1",
      "domain": false,
      "tickColor": "#d7d0dd",
      "labelColor": "#49454f",
      "titleColor": "#49454f"
    },
    "legend": {
      "labelColor": "#49454f"
    }
  }
}
