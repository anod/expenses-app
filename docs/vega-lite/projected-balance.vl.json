{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "description": "Dark themed anchor balance columns with expected spending and split credit-card spending as lines; mirrors the app chart rendered directly with Vega-Lite.",
  "title": {
    "text": "Projected Balance",
    "subtitle": "Columns show anchor balance; lines show expected spending and split credit-card spending",
    "anchor": "start",
    "fontSize": 16,
    "subtitleFontSize": 12,
    "color": "#e6e0e9",
    "subtitleColor": "#cac4d0"
  },
  "width": 680,
  "height": 320,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "data": {
    "values": [
      {
        "date": "2026-01-10",
        "anchorBalance": 18400,
        "spendingAtAnchor": 0,
        "splitCcAtAnchor": 0
      },
      {
        "date": "2026-02-10",
        "anchorBalance": 16250,
        "spendingAtAnchor": 3850,
        "splitCcAtAnchor": 900
      },
      {
        "date": "2026-03-10",
        "anchorBalance": 14100,
        "spendingAtAnchor": 4100,
        "splitCcAtAnchor": 1250
      },
      {
        "date": "2026-04-10",
        "anchorBalance": 11950,
        "spendingAtAnchor": 3950,
        "splitCcAtAnchor": 1500
      },
      {
        "date": "2026-05-10",
        "anchorBalance": 9800,
        "spendingAtAnchor": 4200,
        "splitCcAtAnchor": 1750
      },
      {
        "date": "2026-06-10",
        "anchorBalance": 11200,
        "spendingAtAnchor": 3600,
        "splitCcAtAnchor": 1200
      },
      {
        "date": "2026-07-10",
        "anchorBalance": 8700,
        "spendingAtAnchor": 4550,
        "splitCcAtAnchor": 2100
      }
    ]
  },
  "transform": [
    {
      "calculate": "datum.spendingAtAnchor",
      "as": "expectedSpending"
    },
    {
      "calculate": "datum.splitCcAtAnchor",
      "as": "creditCardPayments"
    }
  ],
  "layer": [
    {
      "transform": [
        {
          "calculate": "'Anchor balance'",
          "as": "metric"
        },
        {
          "calculate": "datum.anchorBalance",
          "as": "metricValue"
        }
      ],
      "mark": {
        "type": "bar",
        "cornerRadiusTopLeft": 5,
        "cornerRadiusTopRight": 5,
        "opacity": 0.96,
        "width": 56,
        "stroke": "#ede7ff",
        "strokeWidth": 0.9
      },
      "encoding": {
        "x": {
          "field": "date",
          "type": "ordinal",
          "title": null,
          "sort": {
            "field": "date",
            "order": "ascending"
          },
          "scale": {
            "paddingInner": 0.08,
            "paddingOuter": 0.03
          },
          "axis": {
            "labelExpr": "timeFormat(toDate(datum.label), '%b %d')",
            "labelAngle": 0,
            "labelFontSize": 12,
            "labelColor": "#cac4d0"
          }
        },
        "y": {
          "field": "anchorBalance",
          "type": "quantitative",
          "title": "Amount",
          "axis": {
            "format": ",.0f",
            "labelFontSize": 11
          }
        },
        "color": {
          "datum": "Anchor balance",
          "type": "nominal",
          "scale": {
            "domain": ["Anchor balance", "Expected spending", "Split CC @ anchor"],
            "range": ["#d0bcff", "#80deea", "#ffb4ab"]
          },
          "legend": {
            "orient": "top",
            "title": null,
            "labelFontSize": 12,
            "labelColor": "#cac4d0",
            "symbolType": "stroke"
          }
        },
        "tooltip": [
          {
            "field": "date",
            "type": "temporal",
            "title": "Anchor period",
            "format": "%b %d, %Y"
          },
          {
            "field": "metric",
            "type": "nominal",
            "title": "Metric"
          },
          {
            "field": "metricValue",
            "type": "quantitative",
            "title": "Amount",
            "format": ",.0f"
          },
          {
            "field": "expectedSpending",
            "type": "quantitative",
            "title": "Expected spending",
            "format": ",.0f"
          },
          {
            "field": "anchorBalance",
            "type": "quantitative",
            "title": "Anchor balance",
            "format": ",.0f"
          },
          {
            "field": "creditCardPayments",
            "type": "quantitative",
            "title": "Split CC @ anchor",
            "format": ",.0f"
          }
        ]
      }
    },
    {
      "transform": [
        {
          "fold": ["expectedSpending", "creditCardPayments"],
          "as": ["lineKey", "metricValue"]
        },
        {
          "calculate": "datum.lineKey === 'expectedSpending' ? 'Expected spending' : 'Split CC @ anchor'",
          "as": "metric"
        }
      ],
      "mark": {
        "type": "line",
        "strokeWidth": 3,
        "interpolate": "monotone",
        "point": false
      },
      "encoding": {
        "x": {
          "field": "date",
          "type": "ordinal",
          "sort": {
            "field": "date",
            "order": "ascending"
          },
          "scale": {
            "paddingInner": 0.08,
            "paddingOuter": 0.03
          }
        },
        "y": {
          "field": "metricValue",
          "type": "quantitative"
        },
        "color": {
          "field": "metric",
          "type": "nominal",
          "scale": {
            "domain": ["Anchor balance", "Expected spending", "Split CC @ anchor"],
            "range": ["#d0bcff", "#80deea", "#ffb4ab"]
          },
          "legend": {
            "orient": "top",
            "title": null,
            "labelFontSize": 12,
            "labelColor": "#cac4d0",
            "symbolType": "stroke"
          }
        },
        "tooltip": [
          {
            "field": "date",
            "type": "temporal",
            "title": "Anchor period",
            "format": "%b %d, %Y"
          },
          {
            "field": "metric",
            "type": "nominal",
            "title": "Metric"
          },
          {
            "field": "metricValue",
            "type": "quantitative",
            "title": "Amount",
            "format": ",.0f"
          },
          {
            "field": "expectedSpending",
            "type": "quantitative",
            "title": "Expected spending",
            "format": ",.0f"
          },
          {
            "field": "anchorBalance",
            "type": "quantitative",
            "title": "Anchor balance",
            "format": ",.0f"
          },
          {
            "field": "creditCardPayments",
            "type": "quantitative",
            "title": "Split CC @ anchor",
            "format": ",.0f"
          }
        ]
      }
    },
    {
      "transform": [
        {
          "fold": ["expectedSpending", "creditCardPayments"],
          "as": ["lineKey", "metricValue"]
        },
        {
          "calculate": "datum.lineKey === 'expectedSpending' ? 'Expected spending' : 'Split CC @ anchor'",
          "as": "metric"
        }
      ],
      "mark": {
        "type": "point",
        "filled": true,
        "size": 72,
        "stroke": "#211f26",
        "strokeWidth": 1.5
      },
      "encoding": {
        "x": {
          "field": "date",
          "type": "ordinal",
          "sort": {
            "field": "date",
            "order": "ascending"
          },
          "scale": {
            "paddingInner": 0.08,
            "paddingOuter": 0.03
          }
        },
        "y": {
          "field": "metricValue",
          "type": "quantitative"
        },
        "color": {
          "field": "metric",
          "type": "nominal",
          "scale": {
            "domain": ["Anchor balance", "Expected spending", "Split CC @ anchor"],
            "range": ["#d0bcff", "#80deea", "#ffb4ab"]
          },
          "legend": {
            "orient": "top",
            "title": null,
            "labelFontSize": 12,
            "labelColor": "#cac4d0",
            "symbolType": "stroke"
          }
        },
        "tooltip": [
          {
            "field": "date",
            "type": "temporal",
            "title": "Anchor period",
            "format": "%b %d, %Y"
          },
          {
            "field": "metric",
            "type": "nominal",
            "title": "Metric"
          },
          {
            "field": "metricValue",
            "type": "quantitative",
            "title": "Amount",
            "format": ",.0f"
          },
          {
            "field": "expectedSpending",
            "type": "quantitative",
            "title": "Expected spending",
            "format": ",.0f"
          },
          {
            "field": "anchorBalance",
            "type": "quantitative",
            "title": "Anchor balance",
            "format": ",.0f"
          },
          {
            "field": "creditCardPayments",
            "type": "quantitative",
            "title": "Split CC @ anchor",
            "format": ",.0f"
          }
        ]
      }
    }
  ],
  "config": {
    "background": "#211f26",
    "view": {
      "stroke": null
    },
    "axis": {
      "grid": true,
      "gridColor": "#49454f",
      "gridOpacity": 0.55,
      "domain": false,
      "tickColor": "#49454f",
      "labelColor": "#cac4d0",
      "titleColor": "#e6e0e9"
    },
    "legend": {
      "labelColor": "#cac4d0"
    }
  }
}
