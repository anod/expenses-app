  },
  "dependencies": {
    "@expenses/shared": "*",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "jose": "^6.2.3",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^11.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.0",
    "@types/node": "^22.7.5",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  }
